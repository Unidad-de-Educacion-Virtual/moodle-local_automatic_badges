<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/automatic_badges/db" VERSION="2025070300" COMMENT="Instalación de tablas del plugin automatic_badges" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../lib/xmldb/xmldb.xsd">
  <TABLES>
  
    <!-- Tabla principal de reglas -->
    <TABLE NAME="local_automatic_badges_rules" COMMENT="Reglas para asignar insignias automáticamente">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="badgeid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="criterion_type" TYPE="char" LENGTH="50" NOTNULL="true"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="is_global_rule" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="Indica si es una regla global"/>
        <FIELD NAME="activity_type" TYPE="char" LENGTH="50" NOTNULL="false" COMMENT="Tipo de actividad para reglas globales (assign, quiz, forum, etc)"/>
        <FIELD NAME="activityid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="grade_min" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
        <FIELD NAME="grade_operator" TYPE="char" LENGTH="5" NOTNULL="true" DEFAULT=">=" COMMENT="Comparison operator for grade evaluation: >=, >, <=, <, =="/>
        <FIELD NAME="forum_post_count" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="forum_count_type" TYPE="char" LENGTH="20" NOTNULL="false" DEFAULT="all" COMMENT="Type of posts to count: all, replies, topics"/>
        <FIELD NAME="enable_bonus" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="bonus_points" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
        <FIELD NAME="bonus_target_activityid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="notify_enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="notify_message" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="badgeid_idx" UNIQUE="false" FIELDS="badgeid"/>
      </INDEXES>
    </TABLE>

    <!-- Tabla de log -->
    <TABLE NAME="local_automatic_badges_log" COMMENT="Histórico de insignias otorgadas automáticamente">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="badgeid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="ruleid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timeissued" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="bonus_applied" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="bonus_value" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="badgeid_idx" UNIQUE="false" FIELDS="badgeid"/>
        <INDEX NAME="ruleid_idx" UNIQUE="false" FIELDS="ruleid"/>
      </INDEXES>
    </TABLE>

    <!-- Tabla de configuraciones -->
    <TABLE NAME="local_automatic_badges_settings" COMMENT="Configuraciones por curso">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="setting_name" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="setting_value" TYPE="text" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>

    <!-- Tabla de configuración por curso -->
    <TABLE NAME="local_automatic_badges_coursecfg" COMMENT="Configuración de activación del plugin por curso">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_idx" UNIQUE="true" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>

    <!-- Tabla de criterios (legacy, para compatibilidad con observer) -->
    <TABLE NAME="local_automatic_badges_criteria" COMMENT="Criterios de asignación de insignias (legacy)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="badgeid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="grademin" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="badgeid_idx" UNIQUE="false" FIELDS="badgeid"/>
      </INDEXES>
    </TABLE>

  </TABLES>
</XMLDB>
